# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
.vite/
*.local

# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep sample env files
!.env.example
!frontend/.env.example
!backend/.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Uploads (user-generated content) ─────────────────────────────────────────
backend/src/uploads/*
!backend/src/uploads/.gitkeep

# ── Coverage & Testing ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
.cache/
.parcel-cache/